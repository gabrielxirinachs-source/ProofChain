# flyctl launch added from .gitignore
# ── Python ────────────────────────────────
**/__pycache__
**/*.py[cod]
**/*.pyo
**/.venv
**/venv
**/*.egg-info
**/dist
**/build
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache

# ── Environment ───────────────────────────
**/.env
**/*.env.local
**/*.env.production

# ── Node / Frontend ───────────────────────
**/node_modules
**/frontend/dist
**/frontend/.vite
**/*.tsbuildinfo

# ── Docker ────────────────────────────────
**/*.log

# ── IDE ───────────────────────────────────
**/.vscode
**/.idea
**/*.swp
**/*.swo
**/.DS_Store

# ── Data / Secrets ────────────────────────
**/*.pem
**/*.key
**/*.cert
**/secrets

# flyctl launch added from backend/.pytest_cache/.gitignore
# Created by pytest automatically.
backend/.pytest_cache/**/*

# flyctl launch added from backend/.ruff_cache/.gitignore
# Automatically created by ruff.
backend/.ruff_cache/**/*
fly.toml
